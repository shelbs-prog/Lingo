<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_screen_background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:text="Lingo"
            android:textColor="@color/lingo_text_main"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Beginner Spanish"
            android:textAllCaps="true"
            android:textColor="@color/lingo_primary_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            tools:ignore="HardcodedText" />



        <com.google.android.material.card.MaterialCardView
            android:id="@+id/flashcard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/lingo_border"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/flashcard_inner_background"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:text="Word of the Day"
                    android:textAllCaps="true"
                    android:textColor="@color/lingo_primary_dark"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <LinearLayout
                    android:id="@+id/flashcard_front"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:gravity="center"
                    android:minHeight="220dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/frontWord"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hola"
                        android:textColor="@color/lingo_text_main"
                        android:textSize="36sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/frontSentence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Como estas?"
                        android:textColor="@color/lingo_text_muted"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Tap card to flip"
                        android:textColor="@color/lingo_primary_dark"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/flashcardBack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:gravity="center"
                    android:minHeight="220dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/backWord"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hello"
                        android:textColor="@color/lingo_text_main"
                        android:textSize="36sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/backSentence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="How are you?"
                        android:textColor="@color/lingo_text_muted"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Tap card to flip back"
                        android:textColor="@color/lingo_primary_dark"
                        android:textSize="13sp" />
                </LinearLayout>

            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startQuizBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:minHeight="58dp"
            android:text="Start Quiz"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/lingo_primary"
            app:cornerRadius="28dp"
            app:elevation="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/generateExampleBtn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="58dp"
            android:text="Generate AI Example"
            android:textAllCaps="false"
            android:textColor="@color/lingo_primary_dark"
            android:textStyle="bold"
            app:backgroundTint="@color/lingo_surface"
            app:cornerRadius="28dp"
            app:strokeColor="@color/lingo_primary_soft"
            app:strokeWidth="1dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/aiExampleCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:visibility="gone"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/lingo_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/ai_card_background"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:id="@+id/aiExampleTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Practice"
                    android:textColor="@color/lingo_primary_dark"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/aiStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/lingo_text_muted"
                    android:textSize="15sp"
                    tools:text="Generating example..." />

                <TextView
                    android:id="@+id/aiSpanishText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="@color/lingo_text_main"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="Spanish: Hola, Sofia." />

                <TextView
                    android:id="@+id/aiEnglishText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/lingo_text_muted"
                    android:textSize="19sp"
                    tools:text="English: Hello, Sofia." />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <include
            layout="@layout/progress_section"
            android:layout_width="match_parent"
            android:layout_height= "wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>